# =============================================================================
# Hand-drawn Animation Agent — Environment Variables Template
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values below
# 3. NEVER commit .env to git  (.gitignore already excludes it)
# =============================================================================

# -----------------------------------------------------------------------------
# Volcengine 火山引擎  (video generation — JiMeng AI)
# 获取地址: https://console.volcengine.com/iam/keymanage/
# 需要开通: 即梦AI → 图生视频 / OmniHuman 1.5
# -----------------------------------------------------------------------------
VOLC_ACCESSKEY=AKLTxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOLC_SECRETKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# DeepSeek  (LLM for planning + prompt enhancement)
# 获取地址: https://platform.deepseek.com/api_keys
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Feishu (Lark) Bot  飞书机器人
# 1. open.feishu.cn → 创建企业自建应用
# 2. 权限管理 → 开通: im:message:send_as_bot, im:resource
# 3. 事件订阅 → 添加事件: im.message.receive_v1
#    请求地址: https://your-server.com/feishu/event
# 4. 机器人 → 卡片回调地址: https://your-server.com/feishu/card  ← 语言选择按钮需要
# 5. 凭证与基础信息 → 复制 App ID / App Secret
# 6. 事件订阅页面 → 复制 Verification Token
# -----------------------------------------------------------------------------
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=            # 留空即可（除非开启了加密）

# -----------------------------------------------------------------------------
# Replicate  (手办 → 动漫角色 pipeline)
# 1. 注册: https://replicate.com
# 2. Account → API Tokens → 复制 token
# -----------------------------------------------------------------------------
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Freesound  (音效生成 — 免费真实录音库)
# 1. 注册: https://freesound.org/home/register/
# 2. 申请 API key: https://freesound.org/apiv2/apply (免费)
# 3. 用于替代 Replicate stable-audio-open（无需充值）
# -----------------------------------------------------------------------------
FREESOUND_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Public base URL
# 本地开发: 运行 `ngrok http 8000` 后把 https://xxxx.ngrok-free.app 粘贴在这里
# 生产环境: 填写你的服务器域名
# 飞书 bot 下载文件后通过 /media/ 对外提供访问
# -----------------------------------------------------------------------------
PUBLIC_BASE_URL=https://xxxx.ngrok-free.app
